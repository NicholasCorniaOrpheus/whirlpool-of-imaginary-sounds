<!-- GCOMMENT value="@ABOUTIT:	Nel medesimo argomento. (i.e., &quot;Ad istanza del signor Giulio Mosti [...] [per] una gentildonna ragusea chiamata Fiordispina.&quot; Rime 403-406)" -->
<!-- GCOMMENT value="@ABOUTEN:	On the same subject. (i.e., &quot;On behalf of sir Giulio Mosti [...] [for] a lady from Ragusa named Fiordispina.&quot; Rime 403)" -->
<!-- GCOMMENT value="@EDITOR:	Solerti, Angelo" -->
<!-- GCOMMENT value="@EDITION_TITLE: Le Rime di Torquato Tasso" -->
<!-- GCOMMENT value="@EDITION_LOC:	Bologna" -->
<!-- GCOMMENT value="@EDITION_PUB:	Romagnoli-Dall’Acqua" -->
<!-- GCOMMENT value="@EDITION_DATE:  1898-1902" -->
<!-- GCOMMENT value="@EDITION_VOL:	2" -->
<!-- GCOMMENT value="@EDITION_PAGE:  445" -->
<!-- GCOMMENT value="@TRANSLATOR:	Emiliano Ricciardi and Amyrose McCue Gill" -->
<!-- GCOMMENT value="@VERSE:" -->
<!-- GCOMMENT value="	La natura compose" -->
<!-- GCOMMENT value="	Quest'odorato fiore," -->
<!-- GCOMMENT value="	O pur del magistero egli è d'Amore?" -->
<!-- GCOMMENT value="	Deh! chi tanto vicine" -->
<!-- GCOMMENT value="	Le pene e i dolci premi in lui ripose?" -->
<!-- GCOMMENT value="	E chi d'acute spine" -->
<!-- GCOMMENT value="	Cinse le belle foglie," -->
<!-- GCOMMENT value="	Onde, s'incauta man talora il coglie," -->
<!-- GCOMMENT value="	Punta, in un punto solo" -->
<!-- GCOMMENT value="	Sente allegrezza e duolo?" -->
<!-- GCOMMENT value="	Oh fior meraviglioso, ond'ancor dura" -->
<!-- GCOMMENT value="	Lite incerta d'Amore e di Natura!" -->
<!-- GCOMMENT value="@TVERSE:" -->
<!-- GCOMMENT value="	Did nature create" -->
<!-- GCOMMENT value="	This perfumed flower," -->
<!-- GCOMMENT value="	Or is he instead of Love’s mastery?" -->
<!-- GCOMMENT value="	Oh! Who so near placed" -->
<!-- GCOMMENT value="	The sufferings and the sweet rewards in him?" -->
<!-- GCOMMENT value="	And who with sharp thorns" -->
<!-- GCOMMENT value="	Surrounded the beautiful leaves," -->
<!-- GCOMMENT value="	So that, if a reckless hand picks him," -->
<!-- GCOMMENT value="	Stung, in one place alone" -->
<!-- GCOMMENT value="	It feels happiness and pain?" -->
<!-- GCOMMENT value="	O wonderful flower, in which still endures" -->
<!-- GCOMMENT value="	An unresolved fight between Love and Nature!" -->
<!-- GCOMMENT value="@@END:		VERSES" -->
<!-- GCOMMENT value="@OTHER_CRIT_ED:   None" -->
