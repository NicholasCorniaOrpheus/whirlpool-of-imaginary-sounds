<!-- GCOMMENT value="@@BEGIN:	VERSES" -->
<!-- GCOMMENT value="@ABOUTIT:	Nel medesimo argomento (i.e., &quot;Ad istanza del signor Giulio Mosti [...] [per] una gentildonna ragusea chiamata Fiordispina.&quot; Rime 403-407-408)" -->
<!-- GCOMMENT value="@ABOUTEN:	On the same subject. (i.e., &quot;On behalf of sir Giulio Mosti [...] [for] a lady from Ragusa named Fiordispina.&quot; Rime 403-407-408)" -->
<!-- GCOMMENT value="@EDITOR:	Solerti, Angelo" -->
<!-- GCOMMENT value="@EDITION_TITLE: Le Rime di Torquato Tasso" -->
<!-- GCOMMENT value="@EDITION_LOC:	Bologna" -->
<!-- GCOMMENT value="@EDITION_PUB:	Romagnoli-Dall’Acqua" -->
<!-- GCOMMENT value="@EDITION_DATE:  1898-1902" -->
<!-- GCOMMENT value="@EDITION_VOL:	2" -->
<!-- GCOMMENT value="@EDITION_PAGE:  447" -->
<!-- GCOMMENT value="@TRANSLATOR:	Emiliano Ricciardi and Amyrose McCue Gill" -->
<!-- GCOMMENT value="@VERSE:" -->
<!-- GCOMMENT value="	L'alma con voi mandai" -->
<!-- GCOMMENT value="	Ne la vostra partita," -->
<!-- GCOMMENT value="	Onde, se vivo pur, senz'alma ho vita:" -->
<!-- GCOMMENT value="	E ben di viver parmi," -->
<!-- GCOMMENT value="	Ch'anco fervido è il core" -->
<!-- GCOMMENT value="	Di quel, che lei sì ardea, soave ardore." -->
<!-- GCOMMENT value="	Ma, se vita può darmi" -->
<!-- GCOMMENT value="	Foco de' vostri rai," -->
<!-- GCOMMENT value="	Come mentr'egli vive io morrò mai?" -->
<!-- GCOMMENT value="@TVERSE:" -->
<!-- GCOMMENT value="	My soul with you I sent away" -->
<!-- GCOMMENT value="	In your departure," -->
<!-- GCOMMENT value="	Thus, even if I live, I have a soulless life:" -->
<!-- GCOMMENT value="	[Yet] well it seemed to me to live," -->
<!-- GCOMMENT value="	For still fervid is the heart" -->
<!-- GCOMMENT value="	With that sweet ardor that burned so [for] her." -->
<!-- GCOMMENT value="	But, if life can give me" -->
<!-- GCOMMENT value="	The fire of your eyes," -->
<!-- GCOMMENT value="	How, while [the fire] is alive, will I ever die?" -->
<!-- GCOMMENT value="@@END:		VERSES" -->
<!-- GCOMMENT value="@OTHER_CRIT_ED:   None" -->
<!-- GCOMMENT value="@ATTRIBUTION_ABOUT:	Secure" -->
